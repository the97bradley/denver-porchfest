# Core site
NEXT_PUBLIC_SITE_URL="https://denverporchfest.com"

# Google Analytics (GA4)
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Volunteer backend webhook
VOLUNTEER_APPS_SCRIPT_URL="https://script.google.com/macros/s/REPLACE_ME/exec"

# Google Maps / Places
GOOGLE_MAPS_API_KEY="YOUR_SERVER_KEY"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="YOUR_BROWSER_KEY"

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"

# Eventbrite -> app access pipeline
EVENTBRITE_PRIVATE_TOKEN="replace_me"
EVENTBRITE_WEBHOOK_SECRET="replace_me"
EVENTBRITE_EVENT_URL="https://www.eventbrite.com/e/your-event-id"
EVENTBRITE_EVENT_ID="1987013595152"
EVENTBRITE_WEBHOOK_IDS="15771581"

# Supabase (server-side)
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace_me"

# App routing
APP_BASE_URL="https://denverporchfest.com"
APP_SUCCESS_URL="/app"

# Admin endpoints (manual resync/backfill)
ADMIN_API_SECRET="replace_me"

# Cron protection (for /api/internal/process-retries)
CRON_SECRET="replace_me"

# Access email delivery (Resend)
RESEND_API_KEY="re_xxx"
ACCESS_EMAIL_FROM="Denver PorchFest <info@denverporchfest.com>"
ACCESS_ALERT_TO="info@denverporchfest.com"
